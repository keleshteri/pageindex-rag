# ── Option 1: Anthropic API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Option 2: OpenAI API ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Option 3: Claude Code (no API key needed) ─────────────────────────────────
# Uses your local Claude Code session. Requires `claude` CLI to be installed
# and logged in. Run `claude --version` to confirm it is available.
#
# PAGEINDEX_MODEL=claude-code
# PAGEINDEX_RETRIEVE_MODEL=claude-code

# ── Option 4: Ollama local models (no API key needed) ─────────────────────────
# Requires Ollama running locally: https://ollama.com
# Pull a model first: ollama pull llama3
#
# PAGEINDEX_MODEL=ollama/llama3
# PAGEINDEX_RETRIEVE_MODEL=ollama/llama3
#
# Override the Ollama endpoint if it is not on the default port:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Active model selection ────────────────────────────────────────────────────
# Uncomment one pair from the options above, or pass --model on the CLI.
# PAGEINDEX_MODEL=claude-sonnet-4-6
# PAGEINDEX_RETRIEVE_MODEL=claude-sonnet-4-6
