# Run vulnerability audit automatically after every install/update
audit=true

# Fail (exit 1) if HIGH or CRITICAL vulnerabilities are found
audit-level=high

# Suppress funding solicitation noise
fund=false

# Uncomment to block lifecycle scripts from running during install.
# Prevents malicious postinstall hooks but may break packages that
# compile native binaries (e.g. via node-gyp).
# ignore-scripts=true
